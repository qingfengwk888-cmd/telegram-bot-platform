APP_NAME=telegram-bot-multi-tenant-platform
LOG_LEVEL=INFO

# 本地测试先用 SQLite，后面上 VPS 可换 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# 平台测试机器人 Token，注意不要填原项目正式 Token
PLATFORM_BOT_TOKEN=

# 平台管理员 Chat ID
PLATFORM_ADMIN_CHAT_ID=0
PLATFORM_SECONDARY_ADMIN_CHAT_IDS=

# 内部接口密钥
INTERNAL_API_KEY=

# Codespace / VPS 对外域名
BASE_URL=
